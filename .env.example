VITE_JAZZ_API_KEY=

VITE_BRAND=default
VITE_BRAND_NAME=Round Robin
VITE_BRAND_URL=https://ajedrezroundrobin.com.ar/
VITE_BRAND_OG_IMAGE=https://ajedrezroundrobin.com.ar/pwa-512x512.png
VITE_BRAND_DESCRIPTION=Gestiona torneos de ajedrez por sistema round robin. Fixture automático, posiciones en tiempo real y desempates configurables.

# Métodos de desempate por defecto (orden de prioridad, separados por coma)
VITE_DEFAULT_TIEBREAKS=DE,SB,PN

# Google analytics. Not useful in development, so it can be left empty
VITE_GA_MEASUREMENT_ID=